{
  "name": "TentixClient",
  "version": "1.0.0",
  "description": "TENTIX Client Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.tentix.client",
    "productName": "TENTIX Client",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "TentixTV",
      "repo": "TENTIX-Client"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TENTIX Client",
      "artifactName": "${productName} Setup.${ext}"
    }
  },
  "repository": "github:TentixTV/TENTIX-Client",
  "keywords": [],
  "author": "TENTIX - Sandro",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "javascript-obfuscator": "^5.4.3"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5"
  }
}
